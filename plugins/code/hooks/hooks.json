{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git commit*)",
            "command": "bash ${CLAUDE_PLUGIN_ROOT}/scripts/check-gitignore-security.sh",
            "timeout": 3000
          }
        ]
      }
    ]
  }
}
